    "setting_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z0-9_.*?^$-]+[a-zA-Z0-9_.*\\[\\]{}?^,$:-]*"
    },
    "setting_value": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "xml_function"
          },
          {
            "type": "PATTERN",
            "value": "[^#\\n\\\\\"()]+"
          },
          {
            "type": "STRING",
            "value": "("
          },
          {
            "type": "STRING",
            "value": ")"
          },
          {
            "type": "PATTERN",
            "value": "\\\\[ \\t]*(\\r?\\n)?"
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "comment"
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              },
              {
                "type": "PATTERN",
                "value": "\\r?\\n[ \\t]+"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "string_literal"
          }
        ]
      }
    },
    "xml_function": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "xml"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[ \\t]+"
              },
              {
                "type": "PATTERN",
                "value": "\\\\[ \\t]*\\r?\\n"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^)\"'\\n\\\\]+"
              },
              {
                "type": "PATTERN",
                "value": "\\\\[ \\t]*(\\r?\\n)?"
              },
              {
                "type": "FIELD",
                "name": "xml_content",
                "content": {
                  "type": "SYMBOL",
                  "name": "string_literal"
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "string_literal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\"[^\"\\\\]*(?:\\\\[\\s\\S][^\"\\\\]*)*\""
        },
        {
          "type": "PATTERN",
          "value": "'[^'\\\\]*(?:\\\\[\\s\\S][^'\\\\]*)*'"
        }
      ]
    }
